# GitHub Actions CI — Python
# Generated by cicd-generation skill

name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@{{CHECKOUT_SHA}}
      - uses: actions/setup-python@{{SETUP_PYTHON_SHA}}
        with:
          python-version: '{{PYTHON_VERSION}}'
          cache: 'pip'
      - run: pip install -r {{REQUIREMENTS_FILE}}
      - run: {{LINT_COMMAND}}

  test:
    runs-on: ubuntu-latest
    needs: lint
    steps:
      - uses: actions/checkout@{{CHECKOUT_SHA}}
      - uses: actions/setup-python@{{SETUP_PYTHON_SHA}}
        with:
          python-version: '{{PYTHON_VERSION}}'
          cache: 'pip'
      - run: pip install -r {{REQUIREMENTS_FILE}}
      - run: {{TEST_COMMAND}}
