# Customize: node-version, package manager, test command

name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@{{CHECKOUT_SHA}}
      - uses: actions/setup-node@{{SETUP_NODE_SHA}}
        with:
          node-version: '{{NODE_VERSION}}'
          cache: '{{PACKAGE_MANAGER}}'
      - run: {{INSTALL_COMMAND}}
      - run: {{LINT_COMMAND}}

  test:
    runs-on: ubuntu-latest
    needs: lint
    steps:
      - uses: actions/checkout@{{CHECKOUT_SHA}}
      - uses: actions/setup-node@{{SETUP_NODE_SHA}}
        with:
          node-version: '{{NODE_VERSION}}'
          cache: '{{PACKAGE_MANAGER}}'
      - run: {{INSTALL_COMMAND}}
      - run: {{TEST_COMMAND}}

  build:
    runs-on: ubuntu-latest
    needs: test
    steps:
      - uses: actions/checkout@{{CHECKOUT_SHA}}
      - uses: actions/setup-node@{{SETUP_NODE_SHA}}
        with:
          node-version: '{{NODE_VERSION}}'
          cache: '{{PACKAGE_MANAGER}}'
      - run: {{INSTALL_COMMAND}}
      - run: {{BUILD_COMMAND}}
