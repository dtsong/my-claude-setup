{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "Edit",
      "MultiEdit",
      "Bash(pre-commit run *)",
      "Bash(pytest *)",
      "Bash(python3 *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(gh repo view *)",
      "Bash(gh auth status)",
      "Bash(jq *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/.dev.vars*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/config/database.yml)",
      "Read(**/config/credentials.json)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Edit(**/.env*)",
      "Edit(**/secrets/**)",
      "Edit(**/.ssh/**)",
      "Edit(.github/workflows/*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm publish *)",
      "Bash(curl * | sh)",
      "Bash(wget *)",
      "Bash(chmod *)",
      "Bash(gh repo delete *)",
      "Bash(gh secret set *)",
      "Bash(gh gist create *)",
      "Bash(gh repo create *)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "skillOverrides": {
    "dbt-skill": "off",
    "helm-generation": "off",
    "language-conventions": "off",
    "prompt-wizard": "off",
    "resume-tailor": "off",
    "soc-security": "off",
    "careful": "off",
    "deepen": "off",
    "diagnose": "off",
    "ece": "off",
    "fix": "off",
    "freeze": "off",
    "map": "off",
    "new-python": "off",
    "ops": "off",
    "tailor": "off",
    "cicd-generation": "off",
    "dockerfile-generation": "off",
    "github-workflow": "off",
    "heavy-file-ingestion": "off",
    "web-design-guidelines": "off",
    "web-security-hardening": "off",
    "workflow": "off",
    "analyze-workflow": "off",
    "g": "off",
    "new-terraform": "off",
    "new-typescript": "off",
    "qa": "off",
    "ralf": "off",
    "tdd": "off"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/Development/my-claude-setup/hooks/acceptance-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$HOME/Development/my-claude-setup/hooks/telemetry-dispatch.sh\"; [ -f \"$f\" ] || exit 0; exec bash \"$f\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$HOME/Development/my-claude-setup/hooks/telemetry-dispatch.sh\"; [ -f \"$f\" ] || exit 0; exec bash \"$f\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$HOME/Development/my-claude-setup/hooks/telemetry-dispatch.sh\"; [ -f \"$f\" ] || exit 0; exec bash \"$f\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$HOME/Development/my-claude-setup/hooks/telemetry-dispatch.sh\"; [ -f \"$f\" ] || exit 0; exec bash \"$f\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$HOME/Development/my-claude-setup/hooks/telemetry-dispatch.sh\"; [ -f \"$f\" ] || exit 0; exec bash \"$f\"'",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"$HOME/.bun/bin/bun\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)src/index.ts\"'"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "code-simplifier@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "terraform-skill@antonbabenko": false,
    "swift-lsp@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-codex@skill-codex": true,
    "research-toolkit@skills-dir": false
  },
  "extraKnownMarketplaces": {
    "skill-codex": {
      "source": {
        "source": "github",
        "repo": "skills-directory/skill-codex"
      }
    },
    "research-toolkit-local": {
      "source": {
        "source": "directory",
        "path": "/Users/danielsong/Development/llm/skills/paperbanana-skills"
      }
    }
  },
  "effortLevel": "high",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "openrouter": {
      "command": "/Users/danielsong/Development/my-claude-setup/mcp/openrouter/.venv/bin/python",
      "args": [
        "/Users/danielsong/Development/my-claude-setup/mcp/openrouter/server.py"
      ],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
      }
    }
  }
}
